{
  "name": "tabtally",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "vercel-build": "prisma generate && prisma migrate deploy && next build",
    "check": "next lint && tsc --noEmit",
    "db:generate": "prisma migrate dev",
