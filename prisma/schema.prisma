generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @unique
  email     String    @unique @db.VarChar(100)
  firstName String    @db.VarChar(50)
  lastName  String    @db.VarChar(50)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdGroups              Group[]             @relation("GroupCreator")
  memberships                GroupMember[]       @relation("GroupMemberships")
  sentInvitations            GroupMember[]       @relation("GroupInvitations")
  createdTransactions        Transaction[]       @relation("TransactionCreator")
  paidTransactions           Transaction[]       @relation("TransactionPayer")
  receivedTransactionDetails TransactionDetail[] @relation("TransactionRecipients")

  @@index([email])
}

model Group {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(120)
  description String?   @db.VarChar(255)
  createdById String
  createdBy   User      @relation("GroupCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  members            GroupMember[]
  transactions       Transaction[]
  transactionDetails TransactionDetail[]

  @@index([name])
  @@index([slug])
}

enum GroupMemberStatus {
  INVITED
  JOINED
  BANNED
}

model GroupMember {
  id          Int               @id @default(autoincrement())
  groupId     Int
  group       Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  memberId    String
  member      User              @relation("GroupMemberships", fields: [memberId], references: [id])
  invitedById String
  invitedBy   User              @relation("GroupInvitations", fields: [invitedById], references: [id])
  isAdmin     Boolean           @default(false)
  status      GroupMemberStatus @default(INVITED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  @@unique([groupId, memberId])
  @@index([memberId])
  @@index([invitedById])
}

enum TransactionCategory {
  FOOD
  HOUSING
  TRANSPORTATION
  ENTERTAINMENT
  UTILITIES
  SHOPPING
  HEALTH
  EDUCATION
  TRAVEL
  OTHER
}

model Transaction {
  id              Int                  @id @default(autoincrement())
  createdById     String
  createdBy       User                 @relation("TransactionCreator", fields: [createdById], references: [id])
  payerId         String
  payer           User                 @relation("TransactionPayer", fields: [payerId], references: [id])
  amount          Decimal              @db.Decimal(10, 2)
  description     String?              @db.VarChar(255)
  category        TransactionCategory?
  receiptUrl      String?              @db.VarChar(500)
  isSettlement    Boolean              @default(false)
  transactionDate DateTime             @default(now())
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
  groupId         Int
  group           Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)

  transactionDetails TransactionDetail[]

  @@index([groupId])
  @@index([createdById])
  @@index([payerId])
}

model TransactionDetail {
  id            Int         @id @default(autoincrement())
  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  recipientId   String
  recipient     User        @relation("TransactionRecipients", fields: [recipientId], references: [id])
  groupId       Int
  group         Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  amount        Decimal     @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  @@index([transactionId])
  @@index([recipientId])
  @@index([groupId])
}
